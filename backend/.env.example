# ──────────────────────────────────────────────────────────────────────────────
# VedaAI Backend — Environment Variables Template
# Copy this file to .env and fill in your actual values.
# NEVER commit your .env file — it's gitignored.
# ──────────────────────────────────────────────────────────────────────────────

# MongoDB connection string (MongoDB Atlas or local)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# Backend server port
PORT=5000

# Google Gemini API key — get one at https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Redis connection URL (Upstash or local)
# Local: redis://localhost:6379
# Upstash: rediss://default:<token>@<host>:<port>
REDIS_URL=redis://localhost:6379
